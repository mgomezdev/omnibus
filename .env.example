# Port exposed on the host for the Themis web UI and API.
# The internal container port is always 8000; only the host side is configurable.
HOST_PORT=8001

# OrcaSlicer version to install at container start.
# The AppImage is downloaded once and cached in the orca-slicer named volume.
# Update this value and restart to switch versions without rebuilding the image.
ORCA_VERSION=2.4.1
