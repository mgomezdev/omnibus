# Port exposed on the host for the Themis web UI and API.
# The internal container port is always 8000; only the host side is configurable.
HOST_PORT=8001

# OrcaSlicer version to install at container start.
# The AppImage is downloaded once and cached in the laminus-slicer named volume.
# Update this value and restart to switch versions without rebuilding the image.
ORCA_VERSION=2.4.1

# Host port for the Ordinus (gridfinity-customizer) web UI and API.
# Only used when running docker-compose.local.yml (Ordinus is not in the Hub-only stack).
ORDINUS_PORT=3001

# CORS allowed origin for the Ordinus API.
# Default '*' allows access from any machine on the LAN — suitable for a trusted home workshop.
# To restrict to a specific host: CORS_ORIGIN=http://192.168.1.50:3001
CORS_ORIGIN=*
